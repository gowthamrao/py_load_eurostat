# py_load_eurostat Configuration
#
# This is an example .env file. Copy this to .env and fill in the values.
# The application will load these settings from the .env file.
# Environment variables will always override values in this file.

# -- General Settings --
# The type of database to connect to. Can be "postgres" or "sqlite".
# PY_LOAD_EUROSTAT_DB_TYPE=postgres

# -- Database Settings (for PostgreSQL) --
# PY_LOAD_EUROSTAT_DB__HOST=localhost
# PY_LOAD_EUROSTAT_DB__PORT=5432
# PY_LOAD_EUROSTAT_DB__USER=postgres
# PY_LOAD_EUROSTAT_DB__PASSWORD=your_secret_password
# PY_LOAD_EUROSTAT_DB__NAME=eurostat
# For PostgreSQL, use UNLOGGED tables for staging to improve performance.
# PY_LOAD_EUROSTAT_DB__USE_UNLOGGED_TABLES=true

# -- Cache Settings --
# PY_LOAD_EUROSTAT_CACHE__ENABLED=true
# The filesystem path for storing cached downloads.
# PY_LOAD_EUROSTAT_CACHE__PATH=~/.cache/py-load-eurostat

# -- Logging Settings --
# The logging level, e.g., DEBUG, INFO, WARNING, ERROR.
# PY_LOAD_EUROSTAT_LOG__LEVEL=INFO

# -- Eurostat API Settings --
# The base URL for the Eurostat Dissemination API.
# PY_LOAD_EUROSTAT_EUROSTAT__BASE_URL=https://ec.europa.eu/eurostat/api/dissemination
